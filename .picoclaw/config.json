{
  "agents": {
    "defaults": {
      "workspace": "/data/workspace/ezra-price-scraper/.picoclaw/workspace",
      "model": "openai/gpt-4o-mini",
      "max_tokens": 4096,
      "temperature": 0.3,
      "max_tool_iterations": 20
    }
  },
  "model_list": [
    {
      "model_name": "gpt-4o-mini",
      "model": "openai/gpt-4o-mini",
      "api_key": "YOUR_OPENAI_API_KEY"
    }
  ],
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "YOUR_TELEGRAM_BOT_TOKEN",
      "allow_from": ["EZRA_USER_ID"]
    }
  },
  "tools": {
    "web": {
      "duckduckgo": {
        "enabled": true,
        "max_results": 5
      }
    }
  },
  "heartbeat": {
    "enabled": false
  }
}
